"                                تأسس المصنع كجزء من شركة الشوفان للصناعات "
"البلاستيكية التابعة لمجموعة المجرّي القابضة،\n"
"                                بـ 3 خطوط إنتاج وبأحدث التقنيات.\n"
"                                "
msgstr ""

#: templates/core/about.html:112
msgid "التوسعة الكبرى"
msgstr ""

#: templates/core/about.html:115
